[Unit]
Description=CHEK Edge Stereo Pose Producer
After=chek-edge-stack.service
Requires=chek-edge-stack.service
PartOf=chek-edge-stack.service

[Service]
Type=simple
WorkingDirectory=__EDGE_ROOT__
Environment=CHEK_EDGE_ROOT=__CHEK_EDGE_ROOT__
ExecStart=/usr/bin/env bash __EDGE_ROOT__/scripts/edge_stereo_autostart.sh
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
